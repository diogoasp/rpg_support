# Django
DJANGO_SETTINGS_MODULE=config.settings
DJANGO_SECRET_KEY=replace-with-at-least-50-random-characters
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,web,nginx
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1
# Compatibility aliases for execution outside Docker
DEBUG=True
SECRET_KEY=replace-with-at-least-50-random-characters
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL
POSTGRES_DB=rpg_support
POSTGRES_USER=rpg_user
POSTGRES_PASSWORD=replace-with-a-strong-database-password
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://rpg_user:replace-with-a-strong-database-password@db:5432/rpg_support

# Storage and upload limits (bytes)
STATIC_ROOT=/app/staticfiles
MEDIA_ROOT=/app/media
PROTECTED_MEDIA_ROOT=/app/protected_media
MAX_IMAGE_UPLOAD_SIZE=10485760
MAX_DOCUMENT_UPLOAD_SIZE=20971520
MAX_AUDIO_UPLOAD_SIZE=104857600
MAX_AUDIO_ASSET_UPLOAD_SIZE=104857600
PROTECTED_MEDIA_MODE=django
X_ACCEL_REDIRECT_ENABLED=False
X_ACCEL_REDIRECT_PREFIX=/_protected_media/

# Security: set True/non-zero only after HTTPS is active
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
SESSION_COOKIE_AGE=21600
LOG_LEVEL=INFO

# Runtime / image / Nginx
COMPOSE_PROJECT_NAME=onepiece-rpg
APP_IMAGE_NAME=onepiece-rpg
APP_IMAGE_TAG=development
DOMAIN_NAME=localhost
NGINX_CLIENT_MAX_BODY_SIZE=110m
GUNICORN_WORKERS=2
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=120
HTTP_PORT=80

# Host persistence and backup (use absolute paths on VPS if preferred)
POSTGRES_DATA_DIR=./data/postgres
MEDIA_DATA_DIR=./data/media
PROTECTED_MEDIA_DATA_DIR=./data/protected_media
CERTIFICATES_DIR=./certificates
BACKUP_DIR=./data/backups
BACKUP_RETENTION_DAYS=14
SMOKE_BASE_URL=http://127.0.0.1
