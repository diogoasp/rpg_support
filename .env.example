DEBUG=True
SECRET_KEY=replace-with-a-long-random-value
ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=postgresql://rpg_user:rpg_password@localhost:5432/rpg_support
MAX_IMAGE_UPLOAD_SIZE=10485760
MAX_DOCUMENT_UPLOAD_SIZE=20971520
MAX_AUDIO_UPLOAD_SIZE=104857600
PROTECTED_MEDIA_MODE=django
# Use "x-accel" behind Nginx and map this internal URI to MEDIA_ROOT.
PROTECTED_MEDIA_ACCEL_PREFIX=/_protected_media/
